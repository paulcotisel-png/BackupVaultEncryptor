<Window x:Class="BackupVaultEncryptor.App.UI.FirstUserSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="First User Setup" Height="250" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Username:" />
        <TextBox x:Name="UsernameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,5" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Password:" />
        <PasswordBox x:Name="PasswordBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,5" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Confirm Password:" />
        <PasswordBox x:Name="ConfirmPasswordBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,5" />

        <!-- Brief reminder that passwords cannot be recovered. The full
             irreversible-password warning is shown as a confirmation
             dialog before account creation. -->
        <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,5" TextWrapping="Wrap">
            <Run Text="Important: This app does not use email or online accounts. " />
            <Run Text="If you forget your password, your encrypted data cannot be recovered." />
        </TextBlock>

        <TextBlock x:Name="ErrorTextBlock" Grid.Row="4" Grid.ColumnSpan="2" Foreground="Red" TextWrapping="Wrap" />

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CreateButton" Content="Create" Width="75" Margin="0,0,5,0" IsDefault="True" Click="Create_Click" />
            <Button Content="Cancel" Width="75" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
