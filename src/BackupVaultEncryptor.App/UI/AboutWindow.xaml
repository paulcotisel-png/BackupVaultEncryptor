<Window x:Class="BackupVaultEncryptor.App.UI.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Height="220" Width="400" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="BackupVaultEncryptor" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
            <TextBlock x:Name="VersionTextBlock" Text="Version" Margin="0,0,0,6" />
            <TextBlock TextWrapping="Wrap">
                Encrypt and decrypt backup folders on local or SMB storage using bundled authenticated encryption.
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="80" Content="OK" IsDefault="True" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
