<Project>
  <PropertyGroup>
    <!--
      Simple Windows x64, framework-dependent, multi-file publish profile.

      Usage (from repository root in PowerShell):
      dotnet publish .\src\BackupVaultEncryptor.App\BackupVaultEncryptor.App.csproj -c Release -p:PublishProfile=Win-x64-FD-v1
    -->
    <PublishSingleFile>false</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <SelfContained>false</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
  </PropertyGroup>
</Project>
