<Project>
  <PropertyGroup>
    <!--
      Installer-specific self-contained Windows x64 publish profile.

      Usage (from repository root in PowerShell):
      dotnet publish .\src\BackupVaultEncryptor.App\BackupVaultEncryptor.App.csproj /p:PublishProfile=Win-x64-Installer
    -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <Configuration>Release</Configuration>
    <PublishDir>bin\Release\net8.0-windows\win-x64\publish-installer\</PublishDir>
  </PropertyGroup>
</Project>
