<Window x:Class="BackupVaultEncryptor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BackupVaultEncryptor" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Simple header bar with Help and About buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,5,10,5">
            <Button x:Name="HelpButton" Content="Help" Width="70" Margin="0,0,5,0" Click="HelpButton_Click" />
            <Button x:Name="AboutButton" Content="About" Width="70" Click="AboutButton_Click" />
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Encrypt">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Encrypt source -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Source:" />
                    <TextBox x:Name="SourceTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,5,5" />
                    <Button x:Name="EncryptBrowseSourceButton"
                            Grid.Row="0"
                            Grid.Column="2"
                            Content="Browse"
                            Margin="0,0,0,5"
                            Click="EncryptBrowseSourceButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="EncryptSourceContextMenu">
                                <MenuItem Header="Folder" Click="EncryptSourceFolderMenuItem_Click" />
                                <MenuItem Header="File" Click="EncryptSourceFileMenuItem_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- Encrypt destination -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Destination:" />
                    <TextBox x:Name="DestinationTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,5,5" />
                    <Button x:Name="EncryptBrowseDestinationButton"
                            Grid.Row="1"
                            Grid.Column="2"
                            Content="Browse"
                            Margin="0,0,0,5"
                            Click="EncryptBrowseDestinationButton_Click" />

                    <!-- Encrypt start -->
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,5,0,0">
                        <Button x:Name="EncryptStartButton" Content="Start" Width="80" Click="EncryptStartButton_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Decrypt">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Decrypt source (manifest) -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Manifest:" />
                    <TextBox x:Name="DecryptSourceTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,5,5" />
                    <Button x:Name="DecryptBrowseSourceButton"
                            Grid.Row="0"
                            Grid.Column="2"
                            Content="Browse"
                            Margin="0,0,0,5"
                            Click="DecryptBrowseSourceButton_Click" />

                    <!-- Decrypt destination -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Destination:" />
                    <TextBox x:Name="DecryptDestinationTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,5,5" />
                    <Button x:Name="DecryptBrowseDestinationButton"
                            Grid.Row="1"
                            Grid.Column="2"
                            Content="Browse"
                            Margin="0,0,0,5"
                            Click="DecryptBrowseDestinationButton_Click" />

                    <!-- Decrypt start -->
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,5,0,0">
                        <Button x:Name="DecryptStartButton" Content="Start" Width="80" Click="DecryptStartButton_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Settings">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Bundle size (GiB):" />
                    <TextBox x:Name="BundleSizeGiBTextBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,5" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Chunk size (MiB):" />
                    <TextBox x:Name="ChunkSizeMiBTextBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,5" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center" Text="Scratch path:" />
                    <TextBox x:Name="ScratchPathTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,5,5" />
                    <Button x:Name="ScratchPathBrowseButton"
                            Grid.Row="2"
                            Grid.Column="2"
                            Width="80"
                            Content="Browse"
                            Margin="0,0,0,5"
                            Click="ScratchPathBrowseButton_Click" />

                    <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button x:Name="SaveSettingsButton" Content="Save" Width="80" Click="SaveSettingsButton_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Shared status and progress below workflow tabs -->
        <StackPanel Grid.Row="2" Margin="10,0,10,0">
            <TextBlock x:Name="StatusTextBlock" Margin="0,5,0,5" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                <ProgressBar x:Name="JobProgressBar" Width="200" Height="20" IsIndeterminate="False" Visibility="Collapsed" Margin="0,0,10,0" />
                <Button x:Name="CancelJobButton"
                        Content="Cancel"
                        Width="80"
                        IsEnabled="False"
                        Click="CancelJobButton_Click" />
            </StackPanel>
        </StackPanel>

        <!-- Shared main log area -->
        <TextBox x:Name="MainLogTextBox"
                 Grid.Row="3"
                 Margin="10,10,10,0"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled" />
    </Grid>
</Window>